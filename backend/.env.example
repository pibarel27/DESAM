# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/desam
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/desam
MONGO_URI=mongodb://127.0.0.1:27017/desam

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# ─── Email (Gmail) ────────────────────────────────────────
# Use an App Password, NOT your Gmail login password.
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=desamofficial02@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── CORS ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── One-time admin seed ──────────────────────────────────
# Pick any secret string; used to protect POST /api/admin/seed
SEED_SECRET=pick_a_secret_here
